# --- Server ---------------------------------------------------------------
# Port the HTTP server listens on.
PORT=3001

# --- Database (Supabase Postgres) ------------------------------------------
# Supabase Dashboard -> Project Settings -> Database -> Connection string.
# Use the session pooler URI (port 5432) or transaction pooler (port 6543).
# Example: postgresql://postgres.abcdefghij:YOUR_DB_PASSWORD@aws-0-eu-central-1.pooler.supabase.com:5432/postgres
DATABASE_URL=

# TLS mode for the Postgres connection:
#   require  - TLS without certificate verification (works with the Supabase pooler; default)
#   strict   - TLS with full certificate verification
#   disable  - plain TCP (local Postgres only)
DATABASE_SSL=require

# --- Better Auth ------------------------------------------------------------
# Random secret used to sign sessions/tokens. Generate one with:
#   openssl rand -base64 32     (or: npx @better-auth/cli secret)
BETTER_AUTH_SECRET=

# Public base URL of THIS server (used for auth callbacks and cookies).
BETTER_AUTH_URL=http://localhost:3001

# --- HTTP -------------------------------------------------------------------
# Comma-separated browser origins allowed by CORS (future web client).
# Native clients (Electron main process, mobile) are not affected by CORS.
CORS_ORIGINS=http://localhost:5173

# Requests allowed per IP on /api/auth per 15-minute window.
AUTH_RATE_LIMIT=100

# Set to true when running behind a reverse proxy / load balancer so rate
# limiting sees real client IPs from X-Forwarded-For.
TRUST_PROXY=false
