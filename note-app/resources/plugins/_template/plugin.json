{
  "id": "hello-plugin",
  "name": "Hello Plugin",
  "version": "1.0.0",
  "description": "A copy-paste Prognotic plugin starter.",
  "signature": "prognotic-plugin/v1",
  "entry": "index.cjs",
  "permissions": {
    "blocks": "own",
    "ai": true
  },
  "ai": {
    "systemPrompt": "Help organize short personal log entries. Return concise Markdown and never invent facts that are not present in the note."
  },
  "sidebar": {
    "label": "Hello Plugin",
    "icon": "puzzle"
  },
  "configSchema": [
    {
      "key": "entryTitle",
      "label": "Entry title",
      "description": "Heading added to newly captured entries.",
      "type": "string",
      "default": "Entry"
    }
  ],
  "ui": {
    "type": "note-feed",
    "layout": [
      "header",
      "capture",
      {
        "type": "stat-row",
        "items": [
          { "key": "today", "label": "today" },
          { "key": "unvisited", "label": "need review" },
          { "key": "total", "label": "total" }
        ]
      },
      {
        "type": "empty-state",
        "message": "No entries yet. Add the first one above."
      },
      {
        "type": "grouped-list",
        "groupBy": "today-recent",
        "entry": {
          "type": "entry",
          "content": "body",
          "editor": {
            "type": "entry-editor",
            "command": "saveEntry"
          },
          "deleteCommand": "deleteEntry",
          "actions": [
            {
              "type": "action",
              "command": "summarizeEntry",
              "label": "Summarize",
              "tone": "ai",
              "showWhen": "always",
              "aiPrompt": "Summarize the entry as two short Markdown bullet points."
            },
            {
              "type": "action",
              "command": "markReviewed",
              "label": "Mark reviewed",
              "tone": "review",
              "showWhen": "unvisited"
            }
          ]
        }
      }
    ],
    "capture": {
      "command": "addEntry",
      "label": "Add entry",
      "placeholder": "Write a short entry..."
    }
  }
}
